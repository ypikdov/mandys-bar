# Variables de entorno (ejemplo) — Backend
#
# Copia este archivo como `backend/.env` y completa los valores.

PORT=3000
NODE_ENV=development

# Base de datos (Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
# En producción se verifica TLS por defecto. Usa false solo como compatibilidad temporal.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Opcional si el proveedor requiere CA explícita. Usa \n para saltos de línea.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Auth
JWT_SECRET="change_me_to_at_least_32_random_characters"
JWT_EXPIRES_IN=30d

# Bootstrap de administrador inicial (solo para seeders; no commitear valores reales)
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_PHONE=

# Supabase
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY=

# Webhooks (si aplica)
WEBHOOK_SECRET="change_me"
WEBHOOK_ALLOWED_PROVIDERS="sinpe,whatsapp"
ALLOW_UNSIGNED_WEBHOOKS=false

# ===== CORS / Frontends permitidos =====
# El backend lee tres variables y las une (sin duplicados):
#   - CORS_ORIGINS  → lista separada por comas (recomendado en producción)
#   - FRONTEND_URL  → un solo origen (cliente)
#   - ADMIN_URL     → un solo origen (admin)
#
# Local (default si no se setea nada): localhost:5173 y localhost:5174
FRONTEND_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5174"

# Producción: agrega los dos dominios públicos separados por coma.
# Ejemplo:
# CORS_ORIGINS="https://mandysbar.com,https://admin.mandysbar.com"
CORS_ORIGINS=
