# Variables de entorno (ejemplo)
#
# Copia este archivo como `.env` en la raíz del repo y completa los valores.

# Supabase (solo llaves públicas/anónimas en el frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend (local)
VITE_API_BASE_URL=http://localhost:3000
VITE_BACKEND_URL=http://localhost:3000

# Bootstrap de administrador inicial (solo para seeders; no commitear valores reales)
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_PHONE=
